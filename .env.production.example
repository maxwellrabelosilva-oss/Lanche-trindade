# Exemplo de arquivo .env para produção
# Copie para .env.production e preencha com seus valores

# Banco de dados MySQL
DATABASE_URL=mysql://usuario:senha@host:3306/cardapio

# OAuth Manus Portal
VITE_APP_ID=seu_app_id_aqui
VITE_OAUTH_PORTAL_URL=https://portal.manus.ai

# API Backend (quando hospedado em Railway/Render)
VITE_API_URL=https://seu-projeto.up.railway.app/api/trpc

# Node Environment
NODE_ENV=production
